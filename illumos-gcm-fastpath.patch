+/*
+ * gcm_fastpath128()
+ *
+ * AES-NI + PCLMULQDQ fast path for GCM encrypt and decrypt.
+ * Processes the entire `length` bytes (must be a multiple of AES_BLOCK_LEN)
+ * in two phases:
+ *
+ *   Encrypt: AES-CTR all data via gcm_ctr_intel8, then bulk GHASH ciphertext
+ *   Decrypt: bulk GHASH ciphertext, then AES-CTR all data via gcm_ctr_intel8
+ *
+ * Separating the two phases (rather than interleaving per-8-block) keeps
+ * AES-NI and PCLMULQDQ execution units busy in sustained bursts.
+ *
+ * Callers must have issued GCM_ACCEL_ENTER before calling this function.
+ * length must be a multiple of AES_BLOCK_LEN.
+ * out must be a contiguous buffer of at least `length` bytes.
+ */
+#ifdef __amd64
+static void
+gcm_fastpath128(gcm_ctx_t *ctx, const uint8_t *data, size_t length,
+    uint8_t *out, boolean_t encrypt,
+    int (*encrypt_block)(const void *, const uint8_t *, uint8_t *),
+    void (*xor_block)(uint8_t *, uint8_t *))
+{
+	aes_key_t *ksch = (aes_key_t *)ctx->gcm_keysched;
+	uint64_t counter_mask = ntohll(COUNTER_MASK);
+	uint64_t counter;
+
+	ASSERT((length & (AES_BLOCK_LEN - 1)) == 0);
+
+	/* Decrypt: authenticate ciphertext before decrypting */
+	if (!encrypt) {
+		if (intel_pclmulqdq_instruction_present())
+			gcm_ghash_clmul(ctx->gcm_ghash, ctx->gcm_H_table,
+			    data, length);
+		else
+			for (size_t i = 0; i < length; i += AES_BLOCK_LEN)
+				GHASH(ctx, &data[i], ctx->gcm_ghash);
+	}
+
+	/*
+	 * AES-CTR phase.  GCM pre-increments the counter before encrypting
+	 * each block, so we advance by 1 before the first call.
+	 */
+	counter = ntohll(ctx->gcm_cb[1] & counter_mask) + 1;
+	ctx->gcm_cb[1] = (ctx->gcm_cb[1] & ~counter_mask) |
+	    (htonll(counter) & counter_mask);
+
+	size_t i = 0;
+	for (; i + 8 * AES_BLOCK_LEN <= length; i += 8 * AES_BLOCK_LEN) {
+		gcm_ctr_intel8(ksch->encr_ks.ks32, ksch->nr,
+		    data + i, out + i,
+		    ctx->gcm_cb[0], ntohll(ctx->gcm_cb[1]));
+		counter += 8;
+		ctx->gcm_cb[1] = (ctx->gcm_cb[1] & ~counter_mask) |
+		    (htonll(counter) & counter_mask);
+	}
+	/*
+	 * Tail: 1-7 full blocks remaining (length was not a multiple of 128).
+	 * Use scalar CTR since gcm_ctr_intel8 requires exactly 8 blocks.
+	 */
+	for (; i < length; i += AES_BLOCK_LEN) {
+		uint8_t *outp = out + i;
+		*(uint64_t *)(void *)outp       = ctx->gcm_cb[0];
+		*(uint64_t *)(void *)(outp + 8) = htonll(counter++);
+		ctx->gcm_cb[1] = (ctx->gcm_cb[1] & ~counter_mask) |
+		    (htonll(counter) & counter_mask);
+		encrypt_block(ctx->gcm_keysched, outp, outp);
+		xor_block((uint8_t *)(data + i), outp);
+	}
+
+	/* Encrypt: authenticate ciphertext after encrypting */
+	if (encrypt) {
+		if (intel_pclmulqdq_instruction_present())
+			gcm_ghash_clmul(ctx->gcm_ghash, ctx->gcm_H_table,
+			    out, length);
+		else
+			for (size_t j = 0; j < length; j += AES_BLOCK_LEN)
+				GHASH(ctx, &out[j], ctx->gcm_ghash);
+	}
+
+	ctx->gcm_processed_data_len += length;
+}
